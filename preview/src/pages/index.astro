---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.jsx';
import LiquidGlassCard from '../components/LiquidGlassCard.jsx';

const services = [
  { title: "تحسين محركات البحث (SEO)", description: "بنية تحتية متوافقة تماماً مع خوارزميات الذكاء الاصطناعي لتصدر النتائج." },
  { title: "بناء الهوية البصرية", description: "تصميمات عصرية تتحدث لغة 2026، تعكس قيم علامتك التجارية." },
  { title: "صناعة المحتوى التفاعلي", description: "استراتيجيات محتوى متكاملة تخاطب الجمهور المستهدف وتحولهم لعملاء." }
];
---
<Layout title="أورا للتسويق | هندسة الحضور الرقمي">
	<HeroSection client:load />
	<section className="relative w-full max-w-6xl mx-auto mt-20">
		<div className="text-center mb-16">
			<h2 className="text-3xl font-bold text-aura-primary mb-4">خدمات مصممة للتفوق</h2>
			<p className="text-aura-text/60 max-w-xl mx-auto">نستخدم أحدث التقنيات المعمارية لضمان أداء لا يضاهى لعملائنا.</p>
		</div>
		<div className="grid grid-cols-1 md:grid-cols-3 gap-8 relative z-20">
			{services.map((service, index) => (
				<LiquidGlassCard client:visible title={service.title} description={service.description} delay={index * 0.2} />
			))}
		</div>
	</section>
</Layout>
