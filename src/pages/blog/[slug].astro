---
import '../../styles/global.css';
import { getCollection, render } from 'astro:content';
import Navbar from '../../components/Navbar.jsx';
import Footer from '../../components/Footer.jsx';
import SEO from '../../components/SEO.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.id }, // تغيير slug إلى id
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry); // استخدام render الحديثة
---

<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO title={entry.data.title} description={entry.data.summary} />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&display=swap" rel="stylesheet">
</head>
<body class="bg-[#FDFDFD] font-['DIN_Next_LT_Arabic','Tajawal'] text-[#1A1D20] antialiased">
    <Navbar client:load />
    <main class="relative w-full pt-40 pb-32">
        <div class="container mx-auto px-4 max-w-3xl">
            <h1 class="text-4xl md:text-5xl font-black text-[#1A1D20] mb-8">{entry.data.title}</h1>
            <article class="prose prose-lg md:prose-xl max-w-none">
                <Content />
            </article>
        </div>
    </main>
    <Footer client:load />
</body>
</html>
