---
import '../../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import { getCollection } from 'astro:content';

import Navbar from '../../components/Navbar.jsx';
import Footer from '../../components/Footer.jsx';
import ContactUsBento from '../../components/ContactUsBento.jsx';
import SEO from '../../components/SEO.astro';

let posts = [];
try {
  const allPosts = await getCollection('blog');
  // ترتيب المقالات من الأحدث للأقدم (افتراض وجود حقل date)
  posts = allPosts.sort((a, b) => new Date(b.data.date || Date.now()).valueOf() - new Date(a.data.date || Date.now()).valueOf());
} catch (error) {
  console.error("لا توجد مقالات بعد أو خطأ في الجلب:", error);
}

// دالة لتنسيق التاريخ
const formatDate = (date) => {
  if (!date) return '';
  return new Date(date).toLocaleDateString('ar-SA', { year: 'numeric', month: 'long', day: 'numeric' });
};
---
<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO title="مدونة أورا | أحدث استراتيجيات التسويق الرقمي" description="اكتشف أحدث المقالات، الاستراتيجيات، والتحليلات في عالم التسويق الرقمي وتطوير الأعمال." />
    <ViewTransitions />
</head>
<body class="font-['DIN_Next_LT_Arabic','Tajawal'] bg-[#FDFDFD] text-[#1e293b] antialiased selection:bg-[#58A8B4] selection:text-white overflow-x-hidden">
    
    <Navbar client:load />

    <main class="w-full">
        <section class="relative bg-[#070F1A] pt-40 pb-32 overflow-hidden rounded-b-[3rem] md:rounded-b-[4rem] z-10">
            <div class="absolute inset-0 pointer-events-none flex justify-center items-center">
                <div class="w-[600px] h-[600px] rounded-full bg-[#58A8B4]/10 blur-[130px]"></div>
            </div>
            
            <div class="container mx-auto px-4 max-w-[900px] relative z-10 text-center reveal">
                <span class="inline-flex items-center gap-2 text-[#58A8B4] font-bold tracking-widest uppercase text-sm mb-6">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                    مركز المعرفة
                </span>
                <h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight" style="view-transition-name: hero-title;">
                    مدونة <span class="text-transparent bg-clip-text bg-gradient-to-l from-[#58A8B4] to-[#438FB3]">أورا</span>
                </h1>
                <p class="text-[#B3B7C1] text-lg md:text-xl leading-relaxed font-medium">
                    أحدث الاستراتيجيات، التحليلات، والأسرار التي نستخدمها لصناعة النمو وتصدر المشهد الرقمي.
                </p>
            </div>
        </section>

        <section class="py-24 relative z-0 bg-[#FDFDFD]">
            <div class="container mx-auto px-4 max-w-[1200px]">
                {posts.length > 0 ? (
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        {posts.map((post, i) => (
                            <a href={`/blog/${post.slug}`} class="b-card group relative bg-white border border-[#B3B7C1]/20 rounded-[2rem] overflow-hidden flex flex-col transition-all duration-300 hover:border-[#58A8B4] reveal" style={`--d:${i * 100}ms; text-decoration: none;`}>
                                
                                {/* صورة أو غلاف رمزي للمقال */}
                                <div class="h-48 bg-gradient-to-br from-[#070F1A] to-[#438FB3] relative flex items-center justify-center overflow-hidden">
                                    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.8) 1px, transparent 0); background-size: 20px 20px;"></div>
                                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#58A8B4" stroke-width="1.5" class="relative z-10 transform group-hover:scale-110 transition-transform duration-500"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                                </div>
                                
                                <div class="p-8 flex flex-col flex-1">
                                    <div class="flex items-center justify-between mb-4">
                                        <span class="text-[11px] font-black text-[#58A8B4] uppercase tracking-wider bg-[#58A8B4]/10 px-3 py-1 rounded-full">
                                            {post.data.category || 'تسويق'}
                                        </span>
                                        <span class="text-[#94a3b8] text-xs font-medium">{formatDate(post.data.date)}</span>
                                    </div>
                                    <h3 class="text-xl font-black text-[#070F1A] mb-3 leading-snug group-hover:text-[#438FB3] transition-colors">
                                        {post.data.title}
                                    </h3>
                                    <p class="text-[#475569] text-sm leading-relaxed mb-6 flex-1">
                                        {post.data.description || 'اكتشف التفاصيل الكاملة في هذا المقال الحصري من فريق أورا...'}
                                    </p>
                                    <div class="text-[#58A8B4] font-bold text-sm inline-flex items-center gap-2 group-hover:gap-3 transition-all">
                                        اقرأ المقال <span class="text-lg leading-none">&larr;</span>
                                    </div>
                                </div>
                            </a>
                        ))}
                    </div>
                ) : (
                    <div class="text-center py-20 text-[#B3B7C1] font-bold text-xl border-2 border-dashed border-[#B3B7C1]/20 rounded-3xl">
                        لا توجد مقالات حالياً. جاري تجهيز محتوى حصري!
                    </div>
                )}
            </div>
        </section>

        <section class="py-24 bg-[#F4F8F9] relative z-20">
            <div class="container mx-auto px-4 max-w-[1200px]">
                <ContactUsBento client:load />
            </div>
        </section>
    </main>

    <Footer client:load />

    <style>
        /* كلاس الكروت الخاص بالمدونة ليتم تطبيق الـ 3D Tilt عليه */
        .b-card { will-change: transform; transform-style: preserve-3d; box-shadow: 0 4px 6px rgba(0,0,0,0.02); }
        .b-card:hover { box-shadow: 0 20px 40px rgba(88,168,180,0.12); z-index: 10; }
        
        .reveal { --d: 0ms; opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease var(--d), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1) var(--d); }
        .reveal.in { opacity: 1; transform: none; }
    </style>

    <script is:inline>
        document.addEventListener('astro:page-load', () => {
            // Scroll Reveal
            const obs = new IntersectionObserver((entries) => {
                entries.forEach((e) => {
                    if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); }
                });
            }, { threshold: 0.1 });
            document.querySelectorAll('.reveal').forEach((el) => obs.observe(el));

            // Card Tilt 3D للمدونة
            document.querySelectorAll('.b-card').forEach((card) => {
                card.addEventListener('mousemove', (e) => {
                    const r = card.getBoundingClientRect();
                    const x = (e.clientX - r.left) / r.width - 0.5;
                    const y = (e.clientY - r.top) / r.height - 0.5;
                    card.style.transform = `perspective(800px) rotateY(${x * 6}deg) rotateX(${-y * 6}deg) translateY(-4px)`;
                });
                card.addEventListener('mouseleave', () => {
                    card.style.transform = '';
                });
            });
        });
    </script>
</body>
</html>
