---
import '../../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import { getCollection } from 'astro:content';

import Navbar from '../../components/Navbar.jsx';
import Footer from '../../components/Footer.jsx';
import ContactUsBento from '../../components/ContactUsBento.jsx';
import SEOHead from '../../components/SEOHead.astro';

let posts = [];
try {
  const allPosts = await getCollection('blog');
  posts = allPosts.sort((a, b) => new Date(b.data.date || Date.now()).valueOf() - new Date(a.data.date || Date.now()).valueOf());
} catch (error) {
  console.error("لا توجد مقالات:", error);
}

const formatDate = (date) => {
  if (!date) return '';
  return new Date(date).toLocaleDateString('ar-SA', { year: 'numeric', month: 'long', day: 'numeric' });
};
---
<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEOHead title="مدونة أورا | أحدث استراتيجيات التسويق الرقمي" description="اكتشف أحدث المقالات في عالم التسويق الرقمي وتطوير الأعمال." />
    <ViewTransitions />
</head>
<body class="font-['DIN_Next_LT_Arabic','Tajawal'] bg-[#FDFDFD] text-[#1e293b] antialiased selection:bg-[#58A8B4] selection:text-white overflow-x-hidden">
    
    <Navbar client:load />

    <main class="w-full">
        <section class="relative bg-[#070F1A] pt-40 pb-32 overflow-hidden rounded-b-[3rem] md:rounded-b-[4rem] z-10">
            <div class="absolute inset-0 pointer-events-none flex justify-center items-center">
                <div class="w-[600px] h-[600px] rounded-full bg-[#58A8B4]/10 blur-[130px]"></div>
            </div>
            <div class="container mx-auto px-4 max-w-[900px] relative z-10 text-center reveal">
                <span class="inline-flex items-center gap-2 text-[#58A8B4] font-bold tracking-widest uppercase text-sm mb-6">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                    مركز المعرفة
                </span>
                <h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight" style="view-transition-name: hero-title;">
                    مدونة <span class="text-transparent bg-clip-text bg-gradient-to-l from-[#58A8B4] to-[#438FB3]">أورا</span>
                </h1>
                <p class="text-[#B3B7C1] text-lg md:text-xl leading-relaxed font-medium">أحدث الاستراتيجيات والأسرار التي نستخدمها لصناعة النمو.</p>
            </div>
        </section>

        <section class="py-24 relative z-0 bg-[#FDFDFD]">
            <div class="container mx-auto px-4 max-w-[1200px]">
                {posts.length > 0 ? (
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        {posts.map((post, i) => (
                            <a href={`/blog/${post.slug}`} class="b-card group relative bg-[#070F1A] border border-[#B3B7C1]/20 rounded-[2rem] overflow-hidden flex flex-col min-h-[420px] transition-all duration-300 hover:border-[#58A8B4] reveal" style={`--d:${i * 100}ms; text-decoration: none;`}>
                                
                                {/* الصورة الخلفية */}
                                {post.data.image ? (
                                    <img src={post.data.image} alt={post.data.title} class="absolute inset-0 w-full h-full object-cover opacity-60 transition-transform duration-700 group-hover:scale-110 group-hover:opacity-40" loading="lazy" />
                                ) : (
                                    <div class="absolute inset-0 bg-gradient-to-br from-[#070F1A] to-[#438FB3] transition-transform duration-700 group-hover:scale-110"></div>
                                )}

                                {/* طبقة الحماية المتدرجة لضمان قراءة العنوان (Gradient Overlay) */}
                                <div class="absolute inset-0 bg-gradient-to-t from-[#070F1A] via-[#070F1A]/80 to-[#070F1A]/10"></div>
                                
                                {/* المحتوى */}
                                <div class="relative z-10 p-8 flex flex-col h-full justify-end">
                                    <div class="flex items-center justify-between mb-4">
                                        <span class="text-[11px] font-black text-white uppercase tracking-wider bg-[#58A8B4]/80 backdrop-blur-md px-3 py-1 rounded-full">
                                            {post.data.category || 'تسويق'}
                                        </span>
                                        <span class="text-[#B3B7C1] text-xs font-bold">{formatDate(post.data.date)}</span>
                                    </div>
                                    <h3 class="text-2xl font-black text-white mb-3 leading-snug group-hover:text-[#58A8B4] transition-colors">
                                        {post.data.title}
                                    </h3>
                                    <p class="text-[#B3B7C1] text-sm leading-relaxed line-clamp-2">
                                        {post.data.description}
                                    </p>
                                </div>
                            </a>
                        ))}
                    </div>
                ) : (
                    <div class="text-center py-20 text-[#B3B7C1] font-bold text-xl border-2 border-dashed border-[#B3B7C1]/20 rounded-3xl">لا توجد مقالات حالياً.</div>
                )}
            </div>
        </section>

        <section class="py-24 bg-[#F4F8F9] relative z-20 overflow-hidden">
            <div class="container mx-auto px-4 max-w-[1200px]"><ContactUsBento client:load /></div>
        </section>
    </main>

    <Footer client:load />

    <style>
        .b-card { will-change: transform; transform-style: preserve-3d; box-shadow: 0 10px 30px rgba(7, 15, 26, 0.1); }
        .b-card:hover { box-shadow: 0 20px 40px rgba(88,168,180,0.2); z-index: 10; }
        .reveal { --d: 0ms; opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease var(--d), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1) var(--d); }
        .reveal.in { opacity: 1; transform: none; }
        .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    </style>

    <script is:inline>
        document.addEventListener('astro:page-load', () => {
            const obs = new IntersectionObserver((entries) => {
                entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); } });
            }, { threshold: 0.1 });
            document.querySelectorAll('.reveal').forEach((el) => obs.observe(el));

            document.querySelectorAll('.b-card').forEach((card) => {
                card.addEventListener('mousemove', (e) => {
                    const r = card.getBoundingClientRect();
                    const x = (e.clientX - r.left) / r.width - 0.5;
                    const y = (e.clientY - r.top) / r.height - 0.5;
                    card.style.transform = `perspective(800px) rotateY(${x * 6}deg) rotateX(${-y * 6}deg) translateY(-4px)`;
                });
                card.addEventListener('mouseleave', () => { card.style.transform = ''; });
            });
        });
    </script>
</body>
</html>
