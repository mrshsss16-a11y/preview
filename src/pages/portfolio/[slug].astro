---
import '../../styles/global.css';
import { getCollection, render } from 'astro:content';
import Navbar from '../../components/Navbar.jsx';
import Footer from '../../components/Footer.jsx';
import SEO from '../../components/SEO.astro';

export async function getStaticPaths() {
  const portfolioEntries = await getCollection('portfolio');
  return portfolioEntries.map(entry => ({
    params: { slug: entry.id }, // تغيير slug إلى id
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO title={entry.data.title} />
</head>
<body class="bg-[#FDFDFD] font-['DIN_Next_LT_Arabic','Tajawal'] text-[#1A1D20] antialiased">
    <Navbar client:load />
    <main class="pt-40">
        <section class={`w-full bg-gradient-to-br ${entry.data.gradient} py-20 text-white text-center`}>
            <h1 class="text-5xl font-black">{entry.data.title}</h1>
            <p class="text-xl mt-4">{entry.data.client}</p>
        </section>
        <div class="container mx-auto px-4 max-w-3xl py-20 prose lg:prose-xl">
            <Content />
        </div>
    </main>
    <Footer client:load />
</body>
</html>
