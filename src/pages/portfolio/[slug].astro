---
import '../../styles/global.css';
import { getCollection } from 'astro:content';

import Navbar from '../../components/Navbar.jsx';
import Footer from '../../components/Footer.jsx';
import SEO from '../../components/SEO.astro';

// هذه الدالة تخبر النظام بإنشاء صفحة لكل ملف Markdown
export async function getStaticPaths() {
  const portfolioEntries = await getCollection('portfolio');
  return portfolioEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const title = `${entry.data.title} | ${entry.data.client} | أورا للتسويق`;
---

<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO title={title} description={entry.data.description} />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&display=swap" rel="stylesheet">
</head>
<body class="bg-[#FDFDFD] font-['DIN_Next_LT_Arabic','Tajawal',sans-serif] text-[#1A1D20] antialiased selection:bg-[#58A8B4] selection:text-white">

    <Navbar client:load />

    <main class="relative w-full pt-40 pb-32">
        {/* Header المشروع الملون */}
        <section class={`w-full bg-gradient-to-br ${entry.data.gradient} py-20 px-4 text-center relative overflow-hidden mb-16`}>
            <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9InJnYmEoMjU1LDI1NSwyNTUsMC4wNSkiLz48L3N2Zz4=')] opacity-50 mix-blend-overlay"></div>
            
            <div class="container mx-auto relative z-10 max-w-4xl">
                <span class="inline-block bg-white/20 backdrop-blur-md border border-white/30 text-white px-5 py-2 rounded-full font-bold text-sm mb-6">
                    {entry.data.category}
                </span>
                <h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight">{entry.data.title}</h1>
                <p class="text-xl text-white/80 font-bold">{entry.data.client}</p>
            </div>
        </section>

        {/* محتوى الـ Markdown بتصميم فخم (Typography) */}
        <section class="container mx-auto px-4 max-w-3xl">
            <div class="prose prose-lg md:prose-xl prose-headings:text-[#1A1D20] prose-h2:text-[#438FB3] prose-h2:font-black prose-p:text-[#B3B7C1] prose-a:text-[#58A8B4] prose-strong:text-[#1A1D20] max-w-none">
                <Content />
            </div>

            <div class="mt-20 pt-10 border-t border-[#B3B7C1]/20 text-center">
                <a href="/portfolio" class="inline-flex items-center gap-2 bg-[#58A8B4]/10 hover:bg-[#58A8B4] text-[#438FB3] hover:text-white px-8 py-3 rounded-full font-bold transition-colors">
                    العودة لمعرض الأعمال
                </a>
            </div>
        </section>
    </main>

    <Footer client:load />

</body>
</html>
