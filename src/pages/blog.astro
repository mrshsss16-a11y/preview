---
import '../styles/global.css';
import Navbar from '../components/Navbar.jsx';
import BlogPageContent from '../components/BlogPageContent.jsx';
import Footer from '../components/Footer.jsx';
---

<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>المدونة | أورا للتسويق</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
</head>
<body class="bg-[#FDFDFD] font-['Tajawal',sans-serif] text-[#1A1D20] antialiased overflow-x-hidden">
    <Navbar client:load />
    <main class="min-h-screen">
        <BlogPageContent client:load />
    </main>
    <Footer client:visible />
</body>
</html>
