---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';

import Navbar from '../components/Navbar.jsx';
import ServiceCards from '../components/ServiceCards.astro';
import ContactUsBento from '../components/ContactUsBento.jsx';
import Footer from '../components/Footer.jsx';
import SEOHead from '../components/SEOHead.astro';
---
<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEOHead title="خدماتنا | وكالة أورا للتسويق" description="استكشف قدرات أورا الرقمية. خدمات تسويقية متكاملة (360 درجة) لبناء هالتك الرقمية والسيطرة على السوق." />
    <ViewTransitions />
</head>
<body class="font-['DIN_Next_LT_Arabic','Tajawal'] bg-[#FDFDFD] text-[#1e293b] antialiased selection:bg-[#58A8B4] selection:text-white overflow-x-hidden">
    
    <Navbar client:load />

    <main class="w-full">
        <section class="relative bg-[#070F1A] pt-40 pb-32 overflow-hidden rounded-b-[3rem] z-10">
            <div class="absolute inset-0 pointer-events-none flex justify-center items-center">
                <div class="w-[600px] h-[600px] rounded-full bg-[#58A8B4]/10 blur-[120px]"></div>
            </div>
            
            <div class="container mx-auto px-4 max-w-[900px] relative z-10 text-center">
                <h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight" style="view-transition-name: hero-title;">
                    حلول ذكية لنتائج <span class="text-transparent bg-clip-text bg-gradient-to-l from-[#58A8B4] to-[#438FB3]">استثنائية</span>
                </h1>
                <p class="text-[#B3B7C1] text-lg md:text-xl leading-relaxed font-medium">
                    من تصميم الهوية التي تخطف الأنظار، إلى الحملات التي تضاعف المبيعات. نحن نغطي كافة احتياجاتك الرقمية باحترافية تامة.
                </p>
            </div>
        </section>

        <div class="py-12">
            <ServiceCards />
        </div>

        <section class="py-24 bg-[#FDFDFD] relative z-20">
            <div class="container mx-auto px-4 max-w-[1200px]">
                <ContactUsBento client:load />
            </div>
        </section>
    </main>

    <Footer client:load />
</body>
</html>
