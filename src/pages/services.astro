---
import '../styles/global.css';

import Navbar from '../components/Navbar.jsx';
import ServicesBento from '../components/ServicesBento.jsx';
import ProcessBento from '../components/ProcessBento.jsx';
import ContactUsBento from '../components/ContactUsBento.jsx';
import Footer from '../components/Footer.jsx';
import SEO from '../components/SEO.astro';

const title = "خدماتنا | وكالة أورا للتسويق";
const description = "نقدم حلولاً تسويقية متكاملة تشمل الـ SEO، الهوية البصرية، والحملات الإعلانية الموجهة بالبيانات لدفع نمو أعمالك.";
---

<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO title={title} description={description} />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&display=swap" rel="stylesheet">
</head>
<body class="bg-[#FDFDFD] font-['DIN_Next_LT_Arabic','Tajawal',sans-serif] text-[#1A1D20] antialiased overflow-x-hidden selection:bg-[#58A8B4] selection:text-white">

    <Navbar client:load />

    <main class="relative w-full">
        
        {/* Sub-Hero Section لصفحة الخدمات */}
        <section class="relative pt-40 pb-20 overflow-hidden flex flex-col items-center text-center px-4">
            {/* Geometric SVG Background للاتساق البصري */}
            <div class="absolute inset-0 z-0 pointer-events-none opacity-40">
                <svg class="w-full h-full object-cover" viewBox="0 0 800 400" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
                    <defs>
                        <pattern id="grid-services" width="60" height="60" patternUnits="userSpaceOnUse">
                            <path d="M 60 0 L 0 0 0 60" fill="none" stroke="#B3B7C1" stroke-width="0.5" opacity="0.3"/>
                        </pattern>
                    </defs>
                    <rect width="100%" height="100%" fill="url(#grid-services)" />
                    <circle cx="20%" cy="100%" r="250" fill="#438FB3" opacity="0.04" />
                </svg>
            </div>

            <div class="relative z-10 max-w-3xl mx-auto">
                <div class="inline-flex items-center gap-2 bg-[#58A8B4]/10 border border-[#58A8B4]/20 text-[#438FB3] px-5 py-2 rounded-full font-bold text-sm mb-6">
                    حلول متكاملة
                </div>
                <h1 class="text-4xl md:text-6xl font-black text-[#1A1D20] mb-6">
                    هندسة <span class="text-transparent bg-clip-text bg-gradient-to-l from-[#58A8B4] to-[#438FB3]">رقمية</span> متكاملة.
                </h1>
                <p class="text-lg text-[#B3B7C1] font-medium leading-relaxed">
                    من الفكرة الأولى وحتى تصدر نتائج البحث، نقدم لك باقة من الخدمات المصممة خصيصاً لتحويل زوارك إلى عملاء دائمين.
                </p>
            </div>
        </section>

        {/* Component: Services Cards */}
        <section class="container mx-auto px-4 sm:px-6 lg:px-8 -mt-8 relative z-20 mb-20">
            <ServicesBento client:load />
        </section>

        {/* Component: Working Process (القسم الجديد) */}
        <section class="container mx-auto px-4 sm:px-6 lg:px-8 mb-32 relative z-20">
            <ProcessBento client:load />
        </section>

        {/* Component: Contact Us (Call to Action النهائي) */}
        <section id="contact" class="container mx-auto px-4 sm:px-6 lg:px-8 mb-20 relative z-20">
            <ContactUsBento client:load />
        </section>

    </main>

    <Footer client:load />

</body>
</html>
