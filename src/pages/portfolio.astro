---
import '../styles/global.css';
import { getCollection } from 'astro:content';

import Navbar from '../components/Navbar.jsx';
import PortfolioGrid from '../components/PortfolioGrid.jsx';
import ContactUsBento from '../components/ContactUsBento.jsx';
import Footer from '../components/Footer.jsx';
import SEO from '../components/SEO.astro';

// استدعاء البيانات من النظام (CMS)
const allProjects = await getCollection('portfolio');
const mappedProjects = allProjects.map(p => ({
  title: p.data.title,
  client: p.data.client,
  category: p.data.category,
  desc: p.data.description,
  colSpan: p.data.colSpan,
  gradient: p.data.gradient,
  slug: p.id
})).sort((a, b) => new Date(b.publishDate) - new Date(a.publishDate));

const title = "أعمالنا | وكالة أورا للتسويق";
const description = "تصفح معرض أعمال وكالة أورا، واكتشف كيف ساعدنا شركاءنا في تحقيق نجاحات رقمية غير مسبوقة.";
---

<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO title={title} description={description} />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&display=swap" rel="stylesheet">
</head>
<body class="bg-[#FDFDFD] font-['DIN_Next_LT_Arabic','Tajawal',sans-serif] text-[#1A1D20] antialiased overflow-x-hidden selection:bg-[#58A8B4] selection:text-white">

    <Navbar client:load />

    <main class="relative w-full">
        <section class="relative pt-40 pb-20 overflow-hidden flex flex-col items-center text-center px-4">
            <div class="absolute inset-0 z-0 pointer-events-none opacity-40">
                <svg class="w-full h-full object-cover" viewBox="0 0 800 400" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
                    <defs>
                        <pattern id="grid-portfolio" width="60" height="60" patternUnits="userSpaceOnUse">
                            <path d="M 60 0 L 0 0 0 60" fill="none" stroke="#B3B7C1" stroke-width="0.5" opacity="0.3"/>
                        </pattern>
                    </defs>
                    <rect width="100%" height="100%" fill="url(#grid-portfolio)" />
                    <circle cx="80%" cy="100%" r="200" fill="#58A8B4" opacity="0.05" />
                </svg>
            </div>

            <div class="relative z-10 max-w-3xl mx-auto">
                <div class="inline-flex items-center gap-2 bg-[#58A8B4]/10 border border-[#58A8B4]/20 text-[#438FB3] px-5 py-2 rounded-full font-bold text-sm mb-6">معرض الأعمال</div>
                <h1 class="text-4xl md:text-6xl font-black text-[#1A1D20] mb-6">أعمال تتحدث عن <span class="text-transparent bg-clip-text bg-gradient-to-l from-[#58A8B4] to-[#438FB3]">نفسها.</span></h1>
            </div>
        </section>

        <section class="container mx-auto px-4 sm:px-6 lg:px-8 -mt-8 relative z-20 mb-32">
            {/* إرسال البيانات للمكون */}
            <PortfolioGrid client:load projects={mappedProjects} />
        </section>

        <section id="contact" class="container mx-auto px-4 sm:px-6 lg:px-8 mb-20 relative z-20">
            <div class="text-center mb-12">
                <h2 class="text-3xl font-black text-[#1A1D20]">هل تريد أن يكون مشروعك <span class="text-[#58A8B4]">التالي</span> هنا؟</h2>
            </div>
            <ContactUsBento client:load />
        </section>
    </main>

    <Footer client:load />
</body>
</html>
