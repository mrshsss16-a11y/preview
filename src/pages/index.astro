---
import '../styles/global.css';

import Navbar from '../components/Navbar.jsx';
import HeroSection from '../components/HeroSection.jsx';
import AboutUsBento from '../components/AboutUsBento.jsx';
import ServicesBento from '../components/ServicesBento.jsx';
import CinematicShowreel from '../components/CinematicShowreel.jsx';
import FAQ from '../components/FAQ.jsx';
import ContactUsBento from '../components/ContactUsBento.jsx';
import Footer from '../components/Footer.jsx';
import SEO from '../components/SEO.astro';
---

<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&display=swap" rel="stylesheet">
</head>
<body class="bg-[#FDFDFD] font-['Tajawal',sans-serif] text-[#1A1D20] antialiased overflow-x-hidden selection:bg-[#58A8B4] selection:text-white">

    <Navbar client:load />

    <main class="relative w-full flex flex-col gap-32">
        <section id="hero"><HeroSection client:load /></section>
        
        <section id="about" class="container mx-auto px-4 sm:px-6 lg:px-8"><AboutUsBento client:visible /></section>
        <section id="services" class="container mx-auto px-4 sm:px-6 lg:px-8"><ServicesBento client:visible /></section>
        <section id="showreel" class="container mx-auto px-4 sm:px-6 lg:px-8"><CinematicShowreel client:visible /></section>
        <section id="faq" class="container mx-auto px-4 sm:px-6 lg:px-8"><FAQ client:visible /></section>
        <section id="contact" class="container mx-auto px-4 sm:px-6 lg:px-8"><ContactUsBento client:visible /></section>
    </main>

    <Footer client:visible />

</body>
</html>
