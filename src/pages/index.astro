---
import Layout from '../layouts/Layout.astro';
import SEOHead from '../components/SEOHead.astro';
import Hero from '../components/Hero.astro';
import HaloSeparator from '../components/HaloSeparator.astro';
import Services from '../components/Services.astro';
import PortfolioGrid from '../components/PortfolioGrid.jsx';
import ContactUsBento from '../components/ContactUsBento.jsx';
import { getCollection } from 'astro:content';

let mappedProjects = [];
try {
  const projects = await getCollection('portfolio');
  mappedProjects = projects.map(p => ({
    slug: p.slug,
    title: p.data.title,
    category: p.data.category,
    client: p.data.client,
    gradient: p.data.gradient,
    result: p.data.result,
  }));
} catch (e) {
  console.error("لا توجد أعمال لعرضها");
}
---
<Layout title="وكالة تسويق رقمي في مكة المكرمة | آورا للتسويق">
  <SEOHead 
    title="وكالة تسويق رقمي في مكة المكرمة | آورا للتسويق" 
    description="آورا للتسويق — وكالة رقمية متكاملة من مكة المكرمة. نبني هالتك الفارقة بـ SEO احترافي، هوية بصرية مميزة، وحملات إعلانية قابلة للقياس. ابنِ هالتك اليوم." 
  />
  
  <Hero />
  <HaloSeparator />
  <Services />

  <section class="py-24 bg-[var(--c-light)] relative">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 reveal">
        <span class="text-[var(--c-teal)] font-bold text-sm tracking-wider uppercase mb-2 block">أعمالنا</span>
        <h2 class="text-4xl md:text-5xl font-extrabold text-[#070F1A]">هالات صنعناها</h2>
      </div>
      {mappedProjects.length > 0 ? (
         <PortfolioGrid client:idle projects={mappedProjects} />
      ) : (
         <p class="text-center text-gray-500">جاري إضافة الأعمال...</p>
      )}
    </div>
  </section>

  <section id="contact" class="py-24 bg-[#F4F8F9] relative z-20 overflow-hidden">
      <div class="container mx-auto px-4 max-w-[1200px]">
          <ContactUsBento client:load />
      </div>
  </section>

</Layout>
