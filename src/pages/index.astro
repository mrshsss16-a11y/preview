---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import Navbar from '../components/Navbar.jsx';
import Hero from '../components/Hero.astro';
import ServiceCards from '../components/ServiceCards.astro';
import Testimonials from '../components/Testimonials.astro';
import PortfolioGrid from '../components/PortfolioGrid.jsx';
import ContactUsBento from '../components/ContactUsBento.jsx';
import Footer from '../components/Footer.jsx';
import SEO from '../components/SEO.astro';

let mappedProjects = [];
try {
  const allProjects = await getCollection('portfolio');
  mappedProjects = allProjects.map(p => ({
    title: p.data.title, client: p.data.client, category: p.data.category,
    desc: p.data.description, colSpan: p.data.colSpan, gradient: p.data.gradient, slug: p.id
  })).slice(0, 4);
} catch (error) {}
---
<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO title="وكالة أورا للتسويق | هالتك الفارقة" description="شريكك الاستراتيجي بالسعودية." />
</head>
<body class="font-['DIN_Next_LT_Arabic','Tajawal'] text-[#1e293b] antialiased selection:bg-[#1ABDA8] selection:text-white overflow-x-hidden">
    <Navbar client:load />
    <main class="w-full">
        <Hero />
        <ServiceCards />
        <section id="portfolio" class="py-24 relative z-20">
            <div class="container mx-auto px-4 max-w-[1200px]">
                <div class="text-center mb-16">
                    <span class="text-[#1ABDA8] font-bold tracking-wider uppercase text-sm mb-3 block">أعمالنا</span>
                    <h2 class="text-4xl md:text-5xl font-black text-[#0D1B2A]">هالات <span class="text-transparent bg-clip-text bg-gradient-to-l from-[#1ABDA8] to-[#0F6E56]">صنعناها</span></h2>
                </div>
                {mappedProjects.length > 0 && <PortfolioGrid client:load projects={mappedProjects} />}
                <div class="mt-16 text-center"><a href="/portfolio" class="inline-flex items-center gap-2 bg-transparent border-2 border-[#1ABDA8] text-[#0F6E56] hover:bg-[#1ABDA8] hover:text-white px-10 py-4 rounded-xl font-bold text-lg transition-all">تصفح كافة أعمالنا</a></div>
            </div>
        </section>
        <Testimonials />
        <section id="contact" class="py-24 relative z-20">
            <div class="container mx-auto px-4 max-w-[1200px]"><ContactUsBento client:load /></div>
        </section>
    </main>
    <Footer client:load />
</body>
</html>
