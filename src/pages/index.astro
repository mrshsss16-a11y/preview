---
import '../styles/global.css';
import { getCollection } from 'astro:content';

import Navbar from '../components/Navbar.jsx';
import HeroSection from '../components/HeroSection.jsx';
import AboutUsBento from '../components/AboutUsBento.jsx'; // استدعاء قسم من نحن
import ServicesBento from '../components/ServicesBento.jsx';
import PortfolioGrid from '../components/PortfolioGrid.jsx';
import ContactUsBento from '../components/ContactUsBento.jsx';
import Footer from '../components/Footer.jsx';
import SEO from '../components/SEO.astro';

// جلب أحدث 4 مشاريع من الـ CMS لعرضها في الصفحة الرئيسية
let mappedProjects = [];
try {
  const allProjects = await getCollection('portfolio');
  mappedProjects = allProjects.map(p => ({
    title: p.data.title,
    client: p.data.client,
    category: p.data.category,
    desc: p.data.description,
    colSpan: p.data.colSpan,
    gradient: p.data.gradient,
    slug: p.id
  })).slice(0, 4);
} catch (error) {
  console.error("خطأ في جلب المشاريع:", error);
}
---

<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO title="وكالة أورا للتسويق | هالتك الفارقة" description="شريكك الاستراتيجي بالسعودية. نهندس تجارب رقمية استثنائية ونطبق استراتيجيات متقدمة لتتصدر علامتك." />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&display=swap" rel="stylesheet">
</head>
<body class="bg-[#FDFDFD] font-['DIN_Next_LT_Arabic','Tajawal',sans-serif] text-[#1A1D20] antialiased selection:bg-[#58A8B4] selection:text-white">
    
    <Navbar client:load />

    <main class="w-full overflow-hidden">
        {/* 1. قسم الهيرو الفخم */}
        <HeroSection client:load />

        {/* 2. قسم من نحن وشريط العملاء المتحرك (الذي طلبته) */}
        <section id="about" class="container mx-auto px-4 sm:px-6 lg:px-8 mt-12 mb-32 relative z-20">
            <AboutUsBento client:load />
        </section>

        {/* 3. قسم الخدمات (ماذا نقدم) */}
        <section id="services" class="container mx-auto px-4 sm:px-6 lg:px-8 mb-32 relative z-20">
            <ServicesBento client:load />
        </section>

        {/* 4. مقتطف من معرض الأعمال */}
        <section id="portfolio" class="container mx-auto px-4 sm:px-6 lg:px-8 mb-32 relative z-20">
            <div class="text-center mb-12">
                <span class="text-[#438FB3] font-bold tracking-wider uppercase text-sm mb-3 block">أعمالنا</span>
                <h2 class="text-4xl md:text-5xl font-black text-[#1A1D20]">هالات <span class="text-[#58A8B4]">صنعناها</span></h2>
            </div>
            
            {mappedProjects.length > 0 && (
                <PortfolioGrid client:load projects={mappedProjects} />
            )}
            
            <div class="mt-16 text-center">
                <a href="/portfolio" class="inline-flex items-center gap-2 bg-transparent border-2 border-[#58A8B4] text-[#438FB3] hover:bg-[#58A8B4]/10 px-10 py-4 rounded-xl font-bold text-lg transition-all group">
                    تصفح كافة أعمالنا
                </a>
            </div>
        </section>

        {/* 5. قسم التواصل لإغلاق الصفقات */}
        <section id="contact" class="container mx-auto px-4 sm:px-6 lg:px-8 mb-20 relative z-20">
            <ContactUsBento client:load />
        </section>
    </main>

    <Footer client:load />
</body>
</html>
