---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { ViewTransitions } from 'astro:transitions';

import Navbar from '../components/Navbar.jsx';
import Hero from '../components/Hero.astro';
import ClientMarquee from '../components/ClientMarquee.astro';
import ServiceCards from '../components/ServiceCards.astro';
import PortfolioGrid from '../components/PortfolioGrid.jsx';
import Testimonials from '../components/Testimonials.astro';
import ContactUsBento from '../components/ContactUsBento.jsx';
import Footer from '../components/Footer.jsx';
import SEOHead from '../components/SEOHead.astro';

let mappedProjects = [];
try {
  const allProjects = await getCollection('portfolio');
  mappedProjects = allProjects.map(p => ({
    title: p.data.title, category: p.data.category, slug: p.id
  })).slice(0, 6);
} catch (error) {}
---
<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEOHead title="وكالة أورا للتسويق | هالتك الفارقة" description="شريكك الاستراتيجي بالسعودية." />
    <ViewTransitions />
    <style>
      ::view-transition-old(halo) { animation: halo-out 0.4s ease-in forwards; }
      ::view-transition-new(halo) { animation: halo-in 0.5s ease-out forwards; }
      @keyframes halo-out { to { opacity: 0; transform: scale(1.08); } }
      @keyframes halo-in { from { opacity: 0; transform: scale(0.94); } }
      ::view-transition-old(hero-title) { animation: slide-out 0.3s ease-in forwards; }
      ::view-transition-new(hero-title) { animation: slide-in 0.4s ease-out 0.1s both; }
      @keyframes slide-out { to { opacity: 0; transform: translateY(-16px); } }
      @keyframes slide-in { from { opacity: 0; transform: translateY(16px); } }
    </style>
</head>
<body class="font-['DIN_Next_LT_Arabic','Tajawal'] text-[#1e293b] antialiased selection:bg-[#1ABDA8] selection:text-white overflow-x-hidden">
    <Navbar client:load />
    <main class="w-full">
        <Hero />
        <ClientMarquee />
        <ServiceCards />
        
        <section id="portfolio" class="py-24 relative z-20 bg-white">
            <div class="container mx-auto px-4 max-w-[1200px]">
                <div class="text-center mb-16">
                    <span class="text-[#1ABDA8] font-bold tracking-wider uppercase text-sm mb-3 block">أعمالنا</span>
                    <h2 class="text-4xl md:text-5xl font-black text-[#070F1A]">هالات <span class="text-transparent bg-clip-text bg-gradient-to-l from-[#1ABDA8] to-[#0F6E56]">صنعناها</span></h2>
                </div>
                {mappedProjects.length > 0 && <PortfolioGrid client:idle projects={mappedProjects} />}
                <div class="mt-16 text-center"><a href="/portfolio" class="inline-flex items-center gap-2 bg-transparent border-2 border-[#1ABDA8] text-[#0F6E56] hover:bg-[#1ABDA8] hover:text-white px-10 py-4 rounded-xl font-bold text-lg transition-all">تصفح كافة أعمالنا</a></div>
            </div>
        </section>

        <Testimonials />
        <section id="contact" class="py-24 relative z-20 bg-[#F4F8F9]">
            <div class="container mx-auto px-4 max-w-[1200px]"><ContactUsBento client:load /></div>
        </section>
    </main>
    <Footer client:load />
</body>
</html>
