---
const services = [
  { n:'01', title:'الهوية البصرية',       desc:'هوية تُجسّد روح علامتك وتثبت حضورك القوي في السوق.', cta:'ابدأ هويتك' },
  { n:'02', title:'تحسين محركات البحث',   desc:'تصدر النتائج الأولى وزد زياراتك العضوية والمجانية.', cta:'تصدر الآن' },
  { n:'03', title:'الحملات الإعلانية',    desc:'إدارة حملات Google وMeta باستهداف دقيق وعائد مقاس.',   cta:'أطلق حملتك' },
  { n:'04', title:'صناعة المحتوى',        desc:'محتوى إبداعي يبني علامتك ويصل للقلوب بطريقة جذابة.',   cta:'ابدأ بمحتوى' },
  { n:'05', title:'إدارة التواصل الاجتماعي', desc:'تواجد احترافي يبني مجتمعاً حقيقياً وولاءً حول علامتك.', cta:'أطلق حساباتك' },
  { n:'06', title:'إدارة المتاجر الإلكترونية', desc:'تجربة تسوق سلسة تحول الزوار إلى عملاء دائمين.',  cta:'طوّر متجرك' },
];
---

<section class="services bg-[#F4F8F9] relative z-10" dir="rtl">
  <div class="sec-hdr reveal">
    <span class="eyebrow">ما نقدمه</span>
    <h2>منظومة متكاملة <span class="hl">لتكتمل هالتك</span></h2>
    <p>خدمات تسويقية (360 درجة)، كل ما تحتاجه تحت سقف واحد بتباين مثالي وأداء فائق.</p>
  </div>

  <div class="s-grid">
    {services.map((s, i) => (
      <article class="s-card reveal" style={`--d:${i*80}ms`}>
        <svg class="s-arc" viewBox="0 0 44 44" aria-hidden="true">
          <path d="M7 38 A20 20 0 0 1 37 38" fill="none" stroke="#58A8B4" stroke-width="4" stroke-linecap="round"/>
          <path d="M12 38 A17 17 0 0 1 37 38" fill="none" stroke="#438FB3" stroke-width="3" stroke-linecap="round"/>
          <line x1="37" y1="17" x2="37" y2="38" stroke="#438FB3" stroke-width="3" stroke-linecap="round"/>
          <ellipse cx="25" cy="40.5" rx="11" ry="2.5" fill="#58A8B4" opacity="0.28"/>
        </svg>

        <div class="s-num">{s.n}</div>
        <h3>{s.title}</h3>
        <p>{s.desc}</p>
        <a href="/contact" class="s-cta">{s.cta} <span class="text-[1.2em] leading-none pr-1">&larr;</span></a>
        <div class="s-shine" aria-hidden="true"></div>
      </article>
    ))}
  </div>
</section>

<style>
.services { padding: 100px 5%; }
.sec-hdr  { text-align: center; margin-bottom: 60px; }
.eyebrow  { color: #58A8B4; font-size: 0.85rem; font-weight: 800; letter-spacing:.1em; text-transform:uppercase; display:block; margin-bottom:12px; }
h2        { font-size: clamp(2rem,4vw,3rem); font-weight:900; color:#070F1A; margin-bottom:12px; }
.hl       { background:linear-gradient(135deg,#58A8B4,#438FB3); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
.sec-hdr p { color:#475569; font-size:1.1rem; max-width:500px; margin:0 auto; font-weight: 500; }

.s-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 24px;
  max-width: 1200px; margin: 0 auto;
}

/* ✅ كل الكروت موحدة للتباين المثالي */
.s-card {
  position: relative; overflow: hidden;
  background: #ffffff;
  border: 1px solid rgba(88,168,180,0.15);
  border-radius: 20px;
  padding: 32px 28px;
  display: flex; flex-direction: column; gap: 12px;
  transition: transform 0.15s ease, border-color 0.25s, box-shadow 0.25s;
  will-change: transform;
}
.s-card:hover {
  border-color: #58A8B4;
  box-shadow: 0 16px 40px rgba(88,168,180,0.12);
  z-index: 10;
}
.s-card:hover .s-shine { opacity: 1; }
.s-card:hover .s-cta   { color: #438FB3; letter-spacing: .02em; }

/* Shine overlay */
.s-shine {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 75% 15%, rgba(88,168,180,0.08) 0%, transparent 65%);
  opacity: 0; transition: opacity .35s; pointer-events: none;
}

.s-arc { width: 44px; height: 44px; margin-bottom: 4px; }

.s-num {
  position: absolute; top: 24px; left: 24px;
  font-size: 13px; font-weight: 900;
  color: rgba(88,168,180,0.25); letter-spacing:.05em;
}

h3    { font-size: 1.2rem; font-weight:800; color:#070F1A; }
p     { font-size: 0.95rem;  color:#475569; line-height:1.7; flex:1; font-weight: 500; }

.s-cta {
  color: #58A8B4; font-size:0.95rem; font-weight:700;
  text-decoration:none; display: inline-flex; align-items: center;
  transition: color .2s, letter-spacing .2s; margin-top: 8px;
}

/* Reveal animation */
.reveal {
  --d: 0ms; opacity: 0; transform: translateY(30px);
  transition: opacity .7s ease var(--d), transform .7s cubic-bezier(0.16,1,0.3,1) var(--d);
}
.reveal.in { opacity:1; transform:none; }
</style>

<script is:inline>
  /* تغليف بـ astro:page-load لضمان عملها عند التنقل بـ ViewTransitions */
  document.addEventListener('astro:page-load', function() {
    var obs = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){ e.target.classList.add('in'); obs.unobserve(e.target); }
      });
    },{threshold:0.1});
    
    document.querySelectorAll('.reveal').forEach(function(el){ obs.observe(el); });

    /* Tilt 3D */
    document.querySelectorAll('.s-card').forEach(function(card){
      card.addEventListener('mousemove',function(e){
        var r=card.getBoundingClientRect();
        var x=(e.clientX-r.left)/r.width-.5;
        var y=(e.clientY-r.top)/r.height-.5;
        card.style.transform='perspective(700px) rotateY('+(x*8)+'deg) rotateX('+(-y*8)+'deg) translateY(-6px)';
      });
      card.addEventListener('mouseleave',function(){card.style.transform='';});
    });
  });
</script>
