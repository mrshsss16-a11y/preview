---
// أيقونة القوس الموحدة (Halo Arc Motif) لجميع الخدمات لترسيخ الهوية
const haloIcon = `<svg width="32" height="32" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M 12 28 A 12 12 0 0 1 28 28" /><line x1="28" y1="16" x2="28" y2="28" stroke="currentColor" opacity="0.6" /></svg>`;

const services = [
  {
    id: "branding",
    colSpan: "col-span-1 md:col-span-2 lg:col-span-8",
    bgClass: "bg-[var(--aura-navy)]",
    titleClass: "text-white",
    descClass: "text-white/70",
    iconColor: "var(--aura-cyan)",
    iconBg: "bg-white/5 border border-white/10",
    icon: haloIcon,
    title: 'تصميم الهوية البصرية',
    desc: 'بناء هوية متكاملة تعكس قيمك، تروي قصتك، وتترك انطباعاً لا يُنسى في ذهن عميلك.',
    pattern: `<svg class="absolute left-0 bottom-0 opacity-5 pointer-events-none" width="300" height="300" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"><path d="M -50 200 A 250 250 0 0 1 250 200" fill="none" stroke="#ffffff" stroke-width="40" stroke-linecap="round"/></svg>`
  },
  {
    id: "ads",
    colSpan: "col-span-1 lg:col-span-4",
    bgClass: "bg-white border border-[var(--aura-soft)] shadow-sm",
    titleClass: "text-[var(--aura-navy)]",
    descClass: "text-[var(--aura-navy)]/70",
    iconColor: "var(--aura-teal)",
    iconBg: "bg-[var(--aura-teal)]/5 border border-[var(--aura-teal)]/10",
    icon: haloIcon,
    title: 'الحملات الإعلانية',
    desc: 'إدارة حملات رقمية لاستهداف دقيق ورفع فوري ومستدام للمبيعات.',
    pattern: ''
  },
  {
    id: "content",
    colSpan: "col-span-1 lg:col-span-4",
    bgClass: "bg-white border border-[var(--aura-soft)] shadow-sm",
    titleClass: "text-[var(--aura-navy)]",
    descClass: "text-[var(--aura-navy)]/70",
    iconColor: "var(--aura-cyan)",
    iconBg: "bg-[var(--aura-cyan)]/10 border border-[var(--aura-cyan)]/20",
    icon: haloIcon,
    title: 'صناعة المحتوى',
    desc: 'كتابة إبداعية وتصوير إنتاجي يبرز هوية علامتك ويتحدث بلسان جمهورك.',
    pattern: ''
  },
  {
    id: "social",
    colSpan: "col-span-1 lg:col-span-4",
    bgClass: "bg-[var(--aura-soft)] border border-[var(--aura-cyan)]/20",
    titleClass: "text-[var(--aura-navy)]",
    descClass: "text-[var(--aura-navy)]/80",
    iconColor: "var(--aura-teal)",
    iconBg: "bg-white border border-white",
    icon: haloIcon,
    title: 'إدارة التواصل',
    desc: 'تفاعل مستمر وجدولة احترافية لبناء مجتمع حقيقي حول علامتك.',
    pattern: ''
  },
  {
    id: "seo",
    colSpan: "col-span-1 lg:col-span-4",
    bgClass: "bg-[var(--aura-navy)]",
    titleClass: "text-white",
    descClass: "text-white/70",
    iconColor: "var(--aura-cyan)",
    iconBg: "bg-white/5 border border-white/10",
    icon: haloIcon,
    title: 'تحسين محركات (SEO)',
    desc: 'تصدر نتائج البحث الأولى في جوجل لزيادة الزيارات العضوية.',
    pattern: ''
  },
  {
    id: "ecommerce",
    colSpan: "col-span-1 md:col-span-2 lg:col-span-12",
    bgClass: "bg-[var(--aura-cyan)]",
    titleClass: "text-[var(--aura-navy)]",
    descClass: "text-[var(--aura-navy)]/80",
    iconColor: "var(--aura-navy)",
    iconBg: "bg-[var(--aura-navy)]/10 border border-[var(--aura-navy)]/10",
    icon: haloIcon,
    title: 'إدارة المتاجر الإلكترونية',
    desc: 'تحسين شامل لتجربة المستخدم (UX)، تبسيط رحلة العميل، وزيادة معدلات التحويل وإغلاق الصفقات لمتجرك.',
    pattern: `<svg class="absolute right-0 top-0 opacity-10 pointer-events-none" width="400" height="400" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"><path d="M 50 -50 A 150 150 0 0 0 50 250" fill="none" stroke="var(--aura-navy)" stroke-width="20" stroke-linecap="round"/></svg>`
  }
];
---
<section id="services" class="py-24 relative z-10 bg-[#F4F8F9]" dir="rtl">
  <div class="container mx-auto px-4 max-w-[1200px]">
    
    <div class="text-center mb-16 relative z-20">
      <span class="inline-flex items-center gap-2 text-[var(--aura-teal)] font-bold tracking-widest uppercase text-sm mb-3">
        <Fragment set:html={haloIcon} />
        منظومة متكاملة
      </span>
      <h2 class="text-4xl md:text-5xl font-black text-[var(--aura-navy)] mb-4">نجمع قطع <span class="text-transparent bg-clip-text bg-gradient-to-l from-[var(--aura-cyan)] to-[var(--aura-teal)]">الأحجية</span> لتكتمل هالتك</h2>
      <p class="text-[var(--aura-navy)]/60 font-medium text-lg max-w-2xl mx-auto">خدمات تسويقية متفرقة لا تصنع نجاحاً. في أورا، نصمم لك منظومة تعمل كقطعة واحدة متناغمة.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-6 auto-rows-auto lg:auto-rows-[280px]">
      {services.map((s) => (
        <article class={`group relative overflow-hidden p-8 md:p-10 flex flex-col justify-between rounded-[2rem] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_20px_40px_-15px_rgba(26,189,168,0.2)] ${s.colSpan} ${s.bgClass}`}>
          
          {s.pattern && <div set:html={s.pattern} />}
          
          <div class="absolute inset-0 bg-white/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

          <div class="relative z-10 flex justify-between items-start mb-8 lg:mb-0">
            <div class={`p-4 rounded-2xl w-fit transform group-hover:scale-110 transition-transform duration-500 ${s.iconBg}`} style={`color: ${s.iconColor}`}>
              <Fragment set:html={s.icon} />
            </div>
            <div class={`w-10 h-10 rounded-full flex items-center justify-center opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 bg-black/10`} style={`color: ${s.iconColor}`}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>

          <div class="relative z-10 mt-auto">
            <h3 class={`text-xl md:text-2xl font-black mb-3 ${s.titleClass}`}>{s.title}</h3>
            <p class={`text-base font-medium leading-relaxed max-w-sm ${s.descClass}`}>{s.desc}</p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
