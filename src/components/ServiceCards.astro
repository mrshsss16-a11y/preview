---
const services = [
  {
    id: "branding",
    colSpan: "col-span-1 md:col-span-2 lg:col-span-8",
    bgClass: "bg-white",
    titleClass: "text-[var(--dark)]",
    descClass: "text-[var(--aura-silver)]",
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--aura-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>`,
    title: 'تصميم الهوية البصرية',
    desc: 'بناء هوية متكاملة تعكس قيمك، تروي قصتك، وتترك انطباعاً لا يُنسى في ذهن عميلك.',
    isDark: false
  },
  {
    id: "ads",
    colSpan: "col-span-1 lg:col-span-4",
    bgClass: "bg-[var(--dark)]",
    titleClass: "text-white",
    descClass: "text-[#94a3b8]",
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--aura-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20a8 8 0 1 0 0-16 8 8 0 0 0 0 16Z"/><path d="M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/><path d="M12 2v2"/><path d="M12 22v-2"/><path d="m17 20.66-1-1.73"/><path d="M11 10.27 7 3.34"/><path d="m20.66 17-1.73-1"/><path d="m3.34 7 1.73 1"/><path d="M14 12h8"/><path d="M2 12h2"/><path d="m20.66 7-1.73 1"/><path d="m3.34 17 1.73-1"/><path d="m17 3.34-1 1.73"/><path d="m11 13.73-4 6.93"/></svg>`,
    title: 'الحملات الإعلانية',
    desc: 'إدارة حملات إعلانية لاستهداف دقيق ورفع فوري للمبيعات.',
    isDark: true
  },
  {
    id: "content",
    colSpan: "col-span-1 lg:col-span-4",
    bgClass: "bg-[var(--aura-secondary)]",
    titleClass: "text-white",
    descClass: "text-white/80",
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="m9 15-2 2 2 2"/><path d="m15 19 2-2-2-2"/></svg>`,
    title: 'صناعة المحتوى',
    desc: 'كتابة إبداعية وتصوير إنتاجي يبرز هوية علامتك.',
    isDark: true
  },
  {
    id: "social",
    colSpan: "col-span-1 lg:col-span-4",
    bgClass: "bg-white",
    titleClass: "text-[var(--dark)]",
    descClass: "text-[var(--aura-silver)]",
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--aura-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: 'إدارة التواصل',
    desc: 'تفاعل مستمر وجدولة لبناء مجتمع حول علامتك.',
    isDark: false
  },
  {
    id: "seo",
    colSpan: "col-span-1 lg:col-span-4",
    bgClass: "bg-[var(--dark)]",
    titleClass: "text-white",
    descClass: "text-[#94a3b8]",
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--aura-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="m11 8 3 3-3 3"/></svg>`,
    title: 'تحسين محركات (SEO)',
    desc: 'تصدر نتائج البحث في جوجل لزيادة الزيارات العضوية.',
    isDark: true
  },
  {
    id: "ecommerce",
    colSpan: "col-span-1 md:col-span-2 lg:col-span-12",
    bgClass: "bg-[var(--aura-primary)]",
    titleClass: "text-white",
    descClass: "text-white/90",
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>`,
    title: 'إدارة المتاجر الإلكترونية',
    desc: 'تحسين شامل لتجربة المستخدم وزيادة معدلات التحويل وإغلاق الصفقات لمتجرك الإلكتروني لضمان نمو مبيعاتك.',
    isDark: true
  }
];
---
<section id="services" class="py-24 relative z-10" dir="rtl">
  <div class="container mx-auto px-4 max-w-[1200px]">
    
    <div class="text-center mb-16">
      <span class="inline-block text-[var(--aura-primary)] font-bold tracking-widest uppercase text-sm mb-3">منظومة متكاملة</span>
      <h2 class="text-4xl md:text-5xl font-black text-[var(--dark)] mb-4">نجمع قطع <span class="text-transparent bg-clip-text bg-gradient-to-l from-[var(--aura-primary)] to-[var(--aura-secondary)]">الأحجية</span> لتكتمل هالتك</h2>
      <p class="text-[var(--aura-silver)] font-medium text-lg max-w-2xl mx-auto">خدمات تسويقية متفرقة لا تصنع نجاحاً. في أورا، نصمم لك منظومة تعمل كقطعة واحدة متناغمة.</p>
    </div>

    <div class="bg-[var(--aura-silver)]/20 p-[1px] rounded-[2.5rem] overflow-hidden shadow-2xl shadow-[var(--dark)]/5">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-[1px] auto-rows-auto lg:auto-rows-[260px] bg-[var(--aura-silver)]/20">
        
        {services.map((s) => (
          <article class={`group relative overflow-hidden p-8 flex flex-col justify-between transition-all duration-500 hover:z-10 hover:shadow-2xl ${s.colSpan} ${s.bgClass}`}>
            
            <div class="absolute inset-0 bg-white/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

            <div class="relative z-10 flex justify-between items-start mb-8 lg:mb-0">
              <div class={`p-4 rounded-2xl border backdrop-blur-sm w-fit transform group-hover:scale-110 transition-transform duration-500 ${s.isDark ? 'bg-white/10 border-white/10' : 'bg-[var(--aura-primary)]/5 border-[var(--aura-primary)]/10'}`}>
                <Fragment set:html={s.icon} />
              </div>
              <div class={`w-10 h-10 rounded-full flex items-center justify-center opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 ${s.isDark ? 'bg-white/10' : 'bg-black/5'}`}>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" class={s.titleClass} stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>

            <div class="relative z-10 mt-auto">
              <h3 class={`text-xl md:text-2xl font-black mb-2 ${s.titleClass}`}>{s.title}</h3>
              <p class={`text-sm md:text-base font-medium leading-relaxed max-w-md ${s.descClass}`}>{s.desc}</p>
            </div>
          </article>
        ))}

      </div>
    </div>

  </div>
</section>
