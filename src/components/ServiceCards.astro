---
<section id="services" class="py-24 relative z-10 bg-white" dir="rtl">
  <div class="container mx-auto px-4 max-w-[1200px]">

    <div class="text-center mb-16 relative z-20 reveal">
      <span class="inline-flex items-center gap-2 text-[#58A8B4] font-bold tracking-widest uppercase text-sm mb-3">
        <Fragment set:html={haloIcon} />
        منظومة متكاملة
      </span>
      <h2 class="text-4xl md:text-5xl font-black text-[#070F1A] mb-4">خدمات <span class="text-transparent bg-clip-text bg-gradient-to-l from-[#58A8B4] to-[#438FB3]">تصنع الفارق</span></h2>
      <p class="text-[#475569] font-medium text-lg max-w-2xl mx-auto">نقدم حلولاً تسويقية 360 درجة، مدمجة بلمسة فنية واستراتيجيات مبنية على الأرقام.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-6 auto-rows-auto lg:auto-rows-[280px]">
      {services.map((s, i) => (
        <article class={`s-card group relative overflow-hidden p-8 md:p-10 flex flex-col justify-between rounded-[2rem] shadow-sm transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-[#58A8B4]/15 reveal ${s.colSpan} ${s.bgClass}`} style={`--d:${i * 100}ms`}>

          {s.pattern && <div set:html={s.pattern} />}

          <div class="absolute inset-0 bg-white/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

          <div class="relative z-10 flex justify-between items-start mb-8 lg:mb-0">
            <div class={`p-4 rounded-2xl w-fit transform group-hover:scale-110 transition-transform duration-500 ${s.iconBg} ${s.iconColor}`}>
              <Fragment set:html={haloIcon} />
            </div>
            <div class={`w-10 h-10 rounded-full flex items-center justify-center opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 ${s.arrowBg}`}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>

          <div class="relative z-10 mt-auto">
            <h3 class={`text-xl md:text-2xl font-black mb-3 ${s.titleClass}`}>{s.title}</h3>
            <p class={`text-base font-medium leading-relaxed max-w-sm ${s.descClass}`}>{s.desc}</p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .s-card { will-change: transform; transform-style: preserve-3d; }
  .reveal { --d: 0ms; opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease var(--d), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1) var(--d); }
  .reveal.in { opacity: 1; transform: none; }
</style>

<script is:inline>
  // نستخدم astro:page-load لضمان عمل السكريبتات مع ViewTransitions
  document.addEventListener('astro:page-load', () => {
    
    // 1. تأثير الظهور عند النزول (Scroll Reveal)
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) { 
          e.target.classList.add('in'); 
          obs.unobserve(e.target); 
        }
      });
    }, { threshold: 0.1 });
    
    document.querySelectorAll('.reveal').forEach((el) => obs.observe(el));

    // 2. التمايل المغناطيسي للكروت (3D Tilt)
    document.querySelectorAll('.s-card').forEach((card) => {
      card.addEventListener('mousemove', (e) => {
        const r = card.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - 0.5;
        const y = (e.clientY - r.top) / r.height - 0.5;
        // التمايل باتجاه الماوس
        card.style.transform = `perspective(700px) rotateY(${x * 8}deg) rotateX(${-y * 8}deg) translateY(-6px)`;
      });
      card.addEventListener('mouseleave', () => {
        card.style.transform = '';
      });
    });
  });
</script>
