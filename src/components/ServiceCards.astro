const haloIcon = `<svg width="40" height="40" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-linecap="round"><path d="M7 38 A20 20 0 0 1 37 38" stroke-width="4"/><path d="M12 38 A17 17 0 0 1 37 38" stroke-width="3" opacity="0.7"/><line x1="37" y1="17" x2="37" y2="38" stroke-width="3" opacity="0.7"/><ellipse cx="25" cy="40.5" rx="11" ry="2.5" fill="currentColor" stroke="none" opacity="0.2"/></svg>`;

const services = [
  {
    id: "branding",
    colSpan: "col-span-1 md:col-span-2 lg:col-span-8",
    bgClass: "bg-[#070F1A]",
    titleClass: "text-white",
    descClass: "text-[#B3B7C1]",
    iconColor: "text-[#58A8B4]",
    iconBg: "bg-white/5 border border-white/10",
    arrowBg: "bg-white/10 text-white",
    title: 'تصميم الهوية البصرية',
    desc: 'بناء هوية متكاملة تعكس قيمك، تروي قصتك، وتترك انطباعاً لا يُنسى في ذهن عميلك.',
    pattern: `<svg class="absolute left-0 bottom-0 opacity-5 pointer-events-none" width="200" height="200" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"><circle cx="50" cy="150" r="100" fill="none" stroke="#ffffff" stroke-width="20"/></svg>`
  },
  {
    id: "ads",
    colSpan: "col-span-1 lg:col-span-4",
    bgClass: "bg-white border border-[#B3B7C1]/20",
    titleClass: "text-[#070F1A]",
    descClass: "text-[#475569]",
    iconColor: "text-[#438FB3]",
    iconBg: "bg-[#438FB3]/10 border border-[#438FB3]/20",
    arrowBg: "bg-[#438FB3]/10 text-[#438FB3]",
    title: 'الحملات الإعلانية',
    desc: 'إدارة حملات رقمية لاستهداف دقيق ورفع فوري ومستدام للمبيعات.',
    pattern: ''
  },
  {
    id: "content",
    colSpan: "col-span-1 lg:col-span-4",
    bgClass: "bg-[#F4F8F9] border border-[#B3B7C1]/20",
    titleClass: "text-[#070F1A]",
    descClass: "text-[#475569]",
    iconColor: "text-[#58A8B4]",
    iconBg: "bg-[#58A8B4]/10 border border-[#58A8B4]/20",
    arrowBg: "bg-[#58A8B4]/10 text-[#58A8B4]",
    title: 'صناعة المحتوى',
    desc: 'كتابة إبداعية وتصوير إنتاجي يبرز هوية علامتك ويتحدث بلسان جمهورك.',
    pattern: ''
  },
  {
    id: "social",
    colSpan: "col-span-1 lg:col-span-4",
    bgClass: "bg-white border border-[#B3B7C1]/20",
    titleClass: "text-[#070F1A]",
    descClass: "text-[#475569]",
    iconColor: "text-[#438FB3]",
    iconBg: "bg-[#438FB3]/10 border border-[#438FB3]/20",
    arrowBg: "bg-[#438FB3]/10 text-[#438FB3]",
    title: 'إدارة التواصل',
    desc: 'تفاعل مستمر وجدولة احترافية لبناء مجتمع حقيقي حول علامتك.',
    pattern: ''
  },
  {
    id: "seo",
    colSpan: "col-span-1 lg:col-span-4",
    bgClass: "bg-[#F4F8F9] border border-[#B3B7C1]/20",
    titleClass: "text-[#070F1A]",
    descClass: "text-[#475569]",
    iconColor: "text-[#58A8B4]",
    iconBg: "bg-[#58A8B4]/10 border border-[#58A8B4]/20",
    arrowBg: "bg-[#58A8B4]/10 text-[#58A8B4]",
