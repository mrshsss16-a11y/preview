---
// src/components/HaloSeparator.astro
// فاصل قوس الهالة بين الهيرو الكحلي وباقي الصفحة الفاتحة
---
<div class="relative w-full overflow-hidden leading-none z-20 bg-[#070F1A] -mt-[1px] reveal" style="--d: 500ms;">
  
  <svg class="relative block w-full h-[60px] md:h-[100px] lg:h-[150px]" viewBox="0 0 1200 120" preserveAspectRatio="none">
    
    <path d="M0,120 Q600,-20 1200,120 Z" fill="rgba(26, 189, 168, 0.08)" />
    
    <path d="M0,120 Q600,10 1200,120 Z" fill="#F8FAFB" />
    
    <path d="M0,120 Q600,10 1200,120" fill="none" stroke="#1ABDA8" stroke-width="4" stroke-dasharray="15 15" stroke-linecap="round" class="opacity-70 animate-dash" />
    
  </svg>
</div>

<style>
  /* تأثير سريان الهالة على الخط المتقطع */
  .animate-dash {
    animation: dash-flow 30s linear infinite;
  }
  @keyframes dash-flow {
    from { stroke-dashoffset: 1000; }
    to { stroke-dashoffset: 0; }
  }
</style>
