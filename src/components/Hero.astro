---
// @ts-nocheck
import AnimatedDashboard from './AnimatedDashboard.tsx';
---
<section class="hero-spotlight relative w-full min-h-[90vh] bg-[#070F1A] flex items-center justify-center overflow-hidden pb-20 md:pb-40 pt-24 md:pt-32" style="--x: 50%; --y: 50%;">
  
  <div class="pointer-events-none absolute inset-0 mix-blend-screen transition-opacity duration-300" style="background: radial-gradient(circle 500px at var(--x) var(--y), rgba(26, 189, 168, 0.12), transparent 70%);"></div>
  
  <div class="relative z-10 container mx-auto px-6 max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-center">
      
      <div class="flex flex-col items-center md:items-start text-center md:text-right">

        <h1 class="text-white text-4xl md:text-5xl lg:text-7xl font-black mb-6 leading-tight reveal" style="--d: 100ms;">
          وكالة آورا للتسويق الرقمي
        </h1>
        <p class="text-[#1ABDA8] text-xl md:text-3xl font-bold mb-10 reveal" style="--d: 200ms;">
          هالتك الفارقة تبدأ هنا.
        </p>

        <div class="reveal" style="--d: 300ms;">
          <a href="#contact" class="magnetic-btn group relative inline-flex items-center justify-center px-8 py-4 md:px-10 md:py-4 text-lg font-bold text-white bg-[#0F6E7E] rounded-full overflow-hidden shadow-[0_8px_30px_rgba(15,110,126,0.4)] transition-all duration-300 decoration-none">
            <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-[#1ABDA8] to-[#0F6E7E] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
            <span class="relative z-10 flex items-center gap-3">
              ابنِ هالتك الآن
              <svg class="w-5 h-5 transform rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </span>
          </a>
        </div>
      </div>

      <div class="w-full reveal mt-8 md:mt-0" style="--d: 400ms;">
        <AnimatedDashboard client:visible />
      </div>

    </div>
  </div>
</section>
