---
---
<section class="hero-spotlight relative w-full min-h-[85vh] bg-[#070F1A] flex flex-col items-center justify-center overflow-hidden pb-32" style="--x: 50%; --y: 50%;">
  
  <div class="pointer-events-none absolute inset-0 mix-blend-screen transition-opacity duration-300" style="background: radial-gradient(circle 500px at var(--x) var(--y), rgba(26, 189, 168, 0.12), transparent 70%);"></div>
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[#0F6E7E] rounded-full blur-[150px] opacity-20 transform translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>

  <div class="relative z-10 flex flex-col items-center text-center px-4 max-w-4xl mx-auto mt-16">
    <div class="mb-6 w-24 h-24 relative reveal" style="view-transition-name: halo-motif;">
      <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-[0_0_20px_rgba(26,189,168,0.4)]">
        <path d="M10,50 a40,40 0 1,1 80,0" fill="none" stroke="var(--c-teal)" stroke-width="6" stroke-linecap="round"/>
        <path d="M25,50 a25,25 0 1,1 50,0" fill="none" stroke="var(--c-blue)" stroke-width="4" stroke-linecap="round"/>
      </svg>
    </div>

    <h1 class="text-white text-5xl md:text-7xl font-black mb-6 leading-tight tracking-tight reveal" data-delay="0.1s">
      وكالة آورا للتسويق الرقمي
    </h1>
    <p class="text-transparent bg-clip-text bg-gradient-to-l from-[#1ABDA8] to-[#0F6E7E] text-2xl md:text-4xl font-bold mb-12 reveal" data-delay="0.2s">
      هالتك الفارقة تبدأ هنا.
    </p>

    <div class="reveal" data-delay="0.3s">
      <a href="#contact" class="magnetic-btn group relative inline-flex items-center justify-center px-10 py-4 text-lg font-bold text-white bg-[#0F6E7E] rounded-full overflow-hidden shadow-[0_8px_30px_rgba(15,110,126,0.4)] hover:shadow-[0_8px_40px_rgba(26,189,168,0.5)] transition-all duration-300 decoration-none">
        <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-[#1ABDA8] to-[#0F6E7E] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
        <span class="relative z-10 flex items-center gap-3">
          ابنِ هالتك الآن
          <svg class="w-5 h-5 transform rotate-180 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </span>
      </a>
    </div>
  </div>
</section>
