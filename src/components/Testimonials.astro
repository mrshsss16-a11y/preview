---
const testimonials = [
  { quote: "أورا لم تكن مجرد وكالة تسويق، بل كانوا شركاء استراتيجيين. بفضل منهجيتهم، تضاعفت زيارات موقعنا العضوية 3 مرات خلال 4 أشهر.", name: "م. عبدالله الراجحي", title: "المدير التنفيذي، منصة إعمار", avatar: "ع" },
  { quote: "الهوية البصرية التي ابتكروها لنا غيرت نظرة عملائنا بالكامل. تفاصيل دقيقة، فهم عميق لنفسية المستهلك السعودي، واحترافية لا مثيل لها.", name: "سارة العبداللطيف", title: "مؤسسة علامة فيونكة", avatar: "س" }
];
---
<section class="testimonials section-dark" dir="rtl">
  <div class="testi-inner">
    <div class="section-header">
      <span class="section-eyebrow accent-color">شركاء النجاح</span>
      <h2 class="section-title text-white">لا تأخذ بكلامنا، <span class="hl-light">اسمع منهم</span></h2>
      <p class="section-desc text-muted-light">آراء حقيقية من شركاء وثقوا في هالة "أورا" لتحويل أعمالهم.</p>
    </div>
    <div class="testi-grid">
      {testimonials.map((t) => (
        <div class="testi-card">
          <svg class="quote-icon" width="40" height="40" viewBox="0 0 24 24" fill="var(--primary)" opacity="0.15"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          <p class="quote-text">{t.quote}</p>
          <div class="testi-author">
            <div class="author-avatar">{t.avatar}</div>
            <div class="author-info"><h4 class="author-name">{t.name}</h4><span class="author-title">{t.title}</span></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
<style>
.testimonials { background: var(--dark, #0D1B2A); padding: 100px 5%; position: relative; overflow: hidden; }
.testimonials::before { content: ''; position: absolute; top: -50%; left: -10%; width: 600px; height: 600px; background: radial-gradient(circle, color-mix(in srgb, var(--primary) 15%, transparent) 0%, transparent 70%); pointer-events: none; }
.testi-inner { max-width: 1200px; margin: 0 auto; position: relative; z-index: 1; }
.section-header { text-align: center; margin-bottom: 60px; }
.accent-color { color: var(--primary); font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 12px; font-size: 0.9rem; }
.text-white { color: #fff; font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; margin-bottom: 16px; }
.hl-light { color: var(--primary); }
.text-muted-light { color: #94a3b8; max-width: 500px; margin: 0 auto; line-height: 1.6; font-size: 1.1rem; }
.testi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 30px; }
.testi-card { background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 24px; padding: 40px; position: relative; backdrop-filter: blur(10px); transition: transform 0.3s, background 0.3s; }
.testi-card:hover { transform: translateY(-5px); background: rgba(255, 255, 255, 0.05); border-color: color-mix(in srgb, var(--primary) 30%, transparent); }
.quote-icon { position: absolute; top: 30px; right: 30px; }
.quote-text { color: #e2e8f0; font-size: 1.1rem; line-height: 1.8; margin-top: 20px; margin-bottom: 30px; font-weight: 500; }
.testi-author { display: flex; align-items: center; gap: 16px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 24px; }
.author-avatar { width: 56px; height: 56px; border-radius: 50%; background: var(--primary-dk); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 1.4rem; }
.author-name { color: #fff; font-weight: 800; font-size: 1.1rem; margin-bottom: 4px; }
.author-title { color: #94a3b8; font-size: 0.85rem; font-weight: 500;}
</style>
