---
const reviews = [
  {
    name: "م. خالد الحربي",
    role: "المدير التنفيذي - تيك زون",
    quote: "فريق أورا لم يكتفِ بالتسويق، بل صنعوا لنا هالة رقمية جعلتنا نتصدر السوق في مكة. أرقام المبيعات تضاعفت بفضل استراتيجيتهم.",
    rating: 5
  },
  {
    name: "نورة القحطاني",
    role: "مؤسسة علامة إيفوريا",
    quote: "تصميم الهوية البصرية كان نقطة تحول. لأول مرة نشعر أن شكل علامتنا التجارية يعكس جودة منتجنا الحقيقية. احترافية لا تضاهى.",
    rating: 5
  },
  {
    name: "أحمد باعشن",
    role: "مدير التسويق - المسافر",
    quote: "الحملات الإعلانية مع أورا هي استثمار حقيقي وليست تكلفة. دقة في الاستهداف وشفافية مطلقة في تقارير العائد على الاستثمار (ROAS).",
    rating: 5
  }
];
---
<section class="py-24 bg-[#070F1A] text-white relative overflow-hidden">
  <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] pointer-events-none"></div>
  <div class="container mx-auto px-4 max-w-7xl relative z-10">
    
    <div class="text-center mb-16 reveal">
      <span class="text-[#1ABDA8] font-bold text-sm tracking-wider uppercase mb-2 block">شركاء النجاح</span>
      <h2 class="text-4xl md:text-5xl font-extrabold">هالات تتحدث عن نفسها</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {reviews.map((review, i) => (
        <article class="tilt-card bg-[#0D1B2A] border border-gray-800 rounded-[2rem] p-8 reveal shadow-2xl relative" style={`--delay: ${i * 150}ms`}>
          <svg class="absolute top-6 right-6 w-10 h-10 text-gray-700 opacity-30" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h4v10h-10z" />
          </svg>
          
          <div class="flex gap-1 mb-6">
            {[...Array(review.rating)].map(() => (
              <svg class="w-5 h-5 text-[#1ABDA8]" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            ))}
          </div>
          
          <p class="text-gray-300 text-lg leading-relaxed mb-8 relative z-10 font-medium">"{review.quote}"</p>
          
          <div class="flex items-center gap-4 border-t border-gray-800 pt-6">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-[#1ABDA8] to-[#0F6E7E] flex items-center justify-center text-xl font-bold text-white shadow-lg">
              {review.name.charAt(0)}
            </div>
            <div>
              <h4 class="text-white font-bold text-lg">{review.name}</h4>
              <span class="text-[#1ABDA8] text-sm">{review.role}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
