---
const team = [
  { name: "أحمد الشريف", role: "مؤسس ومدير إبداعي", ini: "أ.ش" },
  { name: "سارة المكاوي", role: "مديرة استراتيجية المحتوى", ini: "س.م" },
  { name: "محمد العتيبي", role: "مختص SEO", ini: "م.ع" },
  { name: "نورة الدوسري", role: "مصممة هوية بصرية", ini: "ن.د" }
];
---
<section class="py-16" dir="rtl">
  <div class="text-center mb-12"><h2 class="text-3xl font-black text-[#070F1A]">فريق الإبداع</h2></div>
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 max-w-6xl mx-auto px-4">
    {team.map((m, i) => (
      <div class="reveal flex flex-col items-center bg-white p-6 rounded-2xl border border-gray-100 shadow-sm" style={`--d:${i * 100}ms`}>
        <div class="relative w-20 h-20 mb-4 flex items-center justify-center rounded-full bg-gradient-to-br from-[#1ABDA8] to-[#0F6E7E] text-white font-black text-2xl shadow-inner">
          {m.ini}
          <svg class="absolute -bottom-2 w-8 h-8 drop-shadow-md" viewBox="0 0 40 20" fill="none"><path d="M 4 4 Q 20 20 36 4" stroke="#1ABDA8" stroke-width="3" stroke-linecap="round" /></svg>
        </div>
        <h3 class="text-[#070F1A] font-bold text-lg">{m.name}</h3>
        <p class="text-[#0F6E7E] text-sm font-medium mt-1">{m.role}</p>
      </div>
    ))}
  </div>
</section>
