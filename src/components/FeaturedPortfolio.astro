---
// @ts-nocheck
export interface Props {
  projects: any[];
}
const { projects } = Astro.props;
// نأخذ أول 3 أعمال فقط للعرض في الرئيسية
const featured = projects.slice(0, 3);
---

<div class="featured-portfolio" dir="rtl">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    {featured.map((p, i) => {
      // استخراج اللون الأساسي من التدرج
      const gradient = p.gradient || 'from-[#58A8B4] to-[#070F1A]';
      const fromColor = gradient.includes('from-[') ? gradient.split('from-[')[1].split(']')[0] : '#58A8B4';
      
      return (
      <a href={`/portfolio/${p.slug}`} class="tilt-card block bg-[#070F1A] rounded-[24px] overflow-hidden border border-[rgba(88,168,180,0.15)] no-underline flex flex-col reveal group" style={`--delay: ${i * 150}ms`}>
        
        <div class="relative h-[240px] flex items-center justify-center overflow-hidden" style={`background: linear-gradient(135deg, ${fromColor} 0%, #070F1A 100%)`}>
          
          {/* الذكاء هنا: إذا كان هناك فيديو اعرضه، وإلا اعرض التصميم العادي */}
          {p.video ? (
            <>
              <video 
                src={p.video} 
                class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700"
                muted loop playsinline
                onmouseover="this.play()" onmouseout="this.pause()"
              ></video>
              <div class="absolute inset-0 bg-gradient-to-t from-[#070F1A] via-transparent to-transparent opacity-60 pointer-events-none"></div>
            </>
          ) : (
            <>
              <div class="absolute inset-0 opacity-30" style="background-image: radial-gradient(circle at 50% 50%, rgba(255,255,255,0.15) 1px, transparent 1px); background-size: 16px 16px;"></div>
              <svg width="60" height="60" viewBox="0 0 44 44" fill="none" stroke="#fff" stroke-opacity="0.3">
                <path d="M7 38 A20 20 0 0 1 37 38" stroke-width="4" stroke-linecap="round"/>
                <circle cx="22" cy="22" r="6" fill="#fff" stroke="none"/>
              </svg>
            </>
          )}
          
          {p.result && (
            <div class="absolute bottom-4 right-4 bg-[#070F1A]/60 backdrop-blur-md border border-white/10 text-[#1ABDA8] px-3 py-1.5 rounded-xl text-xs font-black z-10">
              النتيجة: {p.result}
            </div>
          )}
        </div>
        
        <div class="p-6 flex-1 flex flex-col relative z-10 bg-[#070F1A]">
          <span class="text-[12px] text-[#58A8B4] font-black tracking-wider mb-2">
            {p.category || 'أعمال أورا'}
          </span>
          <h3 class="text-white font-black text-xl mb-2 leading-snug">
            هالة {p.client || 'المشروع'} — من الغياب إلى التصدر
          </h3>
          <p class="text-[#94a3b8] text-sm m-0 leading-relaxed font-medium line-clamp-2">
            {p.title}
          </p>
        </div>

        {/* لمسة آورا الفارقة (توهج عند التمرير) */}
        <div class="absolute -bottom-2 -right-2 w-20 h-20 bg-[#1ABDA8]/10 blur-3xl group-hover:bg-[#1ABDA8]/30 transition-all pointer-events-none z-0"></div>
      </a>
    )})}
  </div>
  
  <div class="mt-16 text-center reveal" style="--delay: 450ms;">
    <a href="/portfolio" class="magnetic-btn group relative inline-flex items-center gap-3 px-8 py-3.5 rounded-full border-2 border-[#070F1A] text-[#070F1A] font-black text-lg hover:bg-[#070F1A] hover:text-white transition-all duration-300 decoration-none overflow-hidden">
      <span class="relative z-10 flex items-center gap-2">
        تصفح السجل الكامل
        <svg viewBox="0 0 60 60" width="60" class="drop-shadow-[0_0_15px_rgba(26,189,168,0.5)]"><path d="M8 55 A30 30 0 0 1 52 55" stroke="#1ABDA8" stroke-width="5" fill="none" stroke-linecap="round"/><path d="M13 55 A25 25 0 0 1 52 55" stroke="#0F6E7E" stroke-width="3" fill="none" stroke-linecap="round"/><line x1="52" y1="25" x2="52" y2="55" stroke="#0F6E7E" stroke-width="3" stroke-linecap="round"/><ellipse cx="32" cy="57" rx="18" ry="3" fill="#1ABDA8" opacity="0.25"/></svg>
      </span>
    </a>
  </div>
</div>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;  
    overflow: hidden;
  }
</style>
