---
const clients = [
  "شركة المسافر", "تيك زون", "إيفوريا للعطور", "مطاعم الكرم", "تطبيق أثر", "متجر عبق",
  "شركة المسافر", "تيك زون", "إيفوريا للعطور", "مطاعم الكرم", "تطبيق أثر", "متجر عبق"
];
---
<section class="bg-[var(--c-light)] py-10 overflow-hidden relative border-b border-gray-200" dir="ltr">
  <div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-[var(--c-light)] to-transparent z-10 pointer-events-none"></div>
  <div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-[var(--c-light)] to-transparent z-10 pointer-events-none"></div>
  
  <div class="marquee-track flex w-max">
    <div class="flex items-center animate-marquee gap-16 px-8">
      {clients.map(client => (
        <div class="text-xl font-black text-gray-400 uppercase tracking-widest hover:text-[#1ABDA8] transition-colors duration-300 cursor-default">
          {client}
        </div>
      ))}
    </div>
    <div class="flex items-center animate-marquee gap-16 px-8" aria-hidden="true">
      {clients.map(client => (
        <div class="text-xl font-black text-gray-400 uppercase tracking-widest hover:text-[#1ABDA8] transition-colors duration-300 cursor-default">
          {client}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .animate-marquee {
    animation: scroll-left 30s linear infinite;
  }
  @keyframes scroll-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }
</style>
