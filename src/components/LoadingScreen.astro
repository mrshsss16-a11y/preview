---
// Cinematic Minimal Loading Screen - Aura Marketing
---
<div id="aura-cinematic-loader" class="fixed inset-0 z-[9999] flex flex-col items-center justify-center bg-[#070F1A] transition-opacity duration-1000" dir="ltr">
  
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[30rem] h-[30rem] bg-[#1ABDA8] rounded-full blur-[150px] opacity-10 animate-pulse-glow pointer-events-none"></div>

  <div class="relative w-32 h-32 mb-10 flex items-center justify-center z-10">
    <svg class="w-full h-full halo-draw" viewBox="0 0 100 100" style="filter: drop-shadow(0 0 12px rgba(0, 255, 255, 0.4));">
      <path d="M 15 75 A 40 40 0 1 1 85 75" fill="none" stroke="#1ABDA8" stroke-width="2.5" stroke-linecap="round" stroke-dasharray="200" stroke-dashoffset="200" />
    </svg>
  </div>

  <div class="w-48 h-[2px] bg-white/5 rounded-full overflow-hidden mb-8 z-10 relative shadow-[0_0_15px_rgba(26,189,168,0.1)]">
    <div id="aura-cinematic-progress" class="h-full bg-gradient-to-r from-[#0F6E7E] to-[#1ABDA8] w-0 transition-all duration-300 ease-out shadow-[0_0_10px_#1ABDA8]"></div>
  </div>

  <h2 class="text-white/90 text-lg md:text-xl font-light font-['Tajawal'] tracking-[0.2em] opacity-0 text-fade-in z-10 relative" dir="rtl">
    آورا للتسويق
  </h2>

</div>

<style>
  /* SVG Draw Animation */
  .halo-draw path {
    animation: drawArc 1.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards 0.2s;
  }
  
  /* Text Fade-in & Float */
  .text-fade-in {
    animation: fadeInText 1.5s ease-out forwards 0.8s;
  }

  /* Deep Background Pulse */
  .animate-pulse-glow {
    animation: pulseGlow 4s ease-in-out infinite alternate;
  }

  @keyframes drawArc {
    0% { stroke-dashoffset: 200; opacity: 0; }
    20% { opacity: 1; }
    100% { stroke-dashoffset: 0; opacity: 1; }
  }

  @keyframes fadeInText {
    0% { opacity: 0; transform: translateY(10px); filter: blur(4px); }
    100% { opacity: 1; transform: translateY(0); filter: blur(0); }
  }

  @keyframes pulseGlow {
    0% { opacity: 0.05; transform: translate(-50%, -50%) scale(0.9); }
    100% { opacity: 0.15; transform: translate(-50%, -50%) scale(1.1); }
  }

  body.is-loading {
    overflow: hidden;
    height: 100vh;
  }
</style>

<script is:inline>
  document.body.classList.add('is-loading');
  let prog = 0;
  const progBar = document.getElementById('aura-cinematic-progress');
  
  // Smooth cinematic progress simulation
  const interval = setInterval(() => { 
    // Fills up to 85% randomly, waits for window load to complete
    prog += Math.random() * 15; 
    if(prog > 85) prog = 85; 
    if(progBar) progBar.style.width = prog + '%'; 
  }, 150);

  window.addEventListener('load', () => {
    clearInterval(interval);
    if(progBar) {
      // Snap to 100%
      progBar.style.width = '100%';
      // Add a slight delay before fading out to let the user enjoy the complete animation
      setTimeout(() => {
        const loader = document.getElementById('aura-cinematic-loader');
        if(loader) loader.style.opacity = '0';
        document.body.classList.remove('is-loading');
        
        // Remove from DOM after fade transition
        setTimeout(() => { 
          if(loader) loader.style.display = 'none'; 
        }, 1000); 
      }, 600); 
    }
  });
</script>
