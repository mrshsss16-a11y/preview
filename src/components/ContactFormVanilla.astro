---
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || '';
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';
---
<div class="bg-[#070F1A]/80 backdrop-blur-xl border border-white/10 rounded-3xl p-8 shadow-2xl w-full max-w-2xl mx-auto min-h-[400px] flex flex-col justify-center" dir="rtl">
  
  <div id="success-screen" class="hidden text-center space-y-6 animate-fade-in">
    <div class="flex justify-center">
        <div class="w-20 h-20 bg-[#1ABDA8]/20 rounded-full flex items-center justify-center border border-[#1ABDA8]/50 shadow-[0_0_30px_rgba(26,189,168,0.3)]">
            <svg class="w-10 h-10 text-[#1ABDA8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
            </svg>
        </div>
    </div>
    
    <div class="space-y-2">
        <h3 class="text-3xl font-bold text-white">تم استلام بياناتك بنجاح</h3>
        <p class="text-[#1ABDA8] text-xl font-medium">شكراً لثقتك بآورا</p>
    </div>

    <div class="py-6 border-y border-white/5">
        <p class="text-gray-400 text-lg leading-relaxed">
            استعد.. نحن الآن نجهز المحرك لنضع معاً
        </p>
        <h2 class="text-2xl md:text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#1ABDA8] to-[#6EE7B7] mt-2">
            لمستك الفارقة في عالم التسويق
        </h2>
    </div>

    <p class="text-sm text-gray-500 italic">سيتواصل معك فريقنا خلال أقل من 24 ساعة</p>
  </div>

  <form id="aura-form" class="space-y-6" data-url={supabaseUrl} data-key={supabaseKey}>
    <h2 class="text-xl font-bold text-white mb-4 border-r-4 border-[#1ABDA8] pr-4">سجل اهتمامك</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label class="block text-sm font-bold text-gray-300 mb-2">الاسم بالكامل</label>
        <input type="text" id="aura-name" placeholder="سلمان هادي" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[#1ABDA8] transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-bold text-gray-300 mb-2">رقم الجوال</label>
        <input type="tel" id="aura-phone" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-left" dir="ltr" placeholder="05xxxxxxxx" />
      </div>
    </div>
    
    <div>
      <label class="block text-sm font-bold text-gray-300 mb-2">تفاصيل المشروع</label>
      <textarea id="aura-message" rows="4" placeholder="كيف يمكن لآورا أن تصنع لك الفارق؟" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[#1ABDA8] transition-colors resize-none"></textarea>
    </div>
    
    <button type="button" id="submit-btn" class="w-full bg-gradient-to-r from-[#1ABDA8] to-[#0F6E7E] p-4 rounded-xl text-white font-bold text-lg transition-all hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-[#1ABDA8]/20">
      إرسال الطلب
    </button>
  </form>
</div>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 0.6s ease-out forwards;
  }
</style>

<script is:inline>
  function initAuraForm() {
    const form = document.getElementById('aura-form');
    const btn = document.getElementById('submit-btn');
    const successScreen = document.getElementById('success-screen');

    if (!form || !btn || form.dataset.ready === "true") return;
    form.dataset.ready = "true";

    btn.addEventListener('click', async () => {
      const name = document.getElementById('aura-name').value;
      const phone = document.getElementById('aura-phone').value;
      const message = document.getElementById('aura-message').value;
      
      if(!name || !message) {
         alert("⚠️ فضلاً، أدخل الاسم وتفاصيل المشروع لنبدأ رحلة التميز.");
         return;
      }

      const url = form.getAttribute('data-url');
      const key = form.getAttribute('data-key');

      btn.innerText = 'جاري المعالجة...';
      btn.disabled = true;

      try {
        const res = await fetch(`${url}/rest/v1/contacts`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'apikey': key,
            'Authorization': `Bearer ${key}`
          },
          body: JSON.stringify({ name, phone, message, email: 'web@aura.com', service: 'طلب من الواجهة' })
        });

        if (!res.ok) throw new Error();

        // السحر هنا: إخفاء الفورم وإظهار السلوجن
        form.classList.add('hidden');
        successScreen.classList.remove('hidden');

      } catch (err) {
        alert("❌ حدث خطأ بسيط، حاول مرة أخرى.");
        btn.innerText = 'إرسال الطلب';
        btn.disabled = false;
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initAuraForm);
  document.addEventListener('astro:page-load', initAuraForm);
</script>
