---
// src/components/FloatingCTA.astro
---
<a href="#contact" id="fcta" dir="rtl" aria-label="ابنِ هالتك الآن">
  ابنِ هالتك الآن &larr;
</a>

<style>
#fcta {
  position: fixed;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  width: calc(100% - 40px);
  max-width: 360px;
  padding: 15px 24px;
  border-radius: 999px;
  background: linear-gradient(135deg, #1ABDA8, #0F6E7E);
  color: #fff;
  font-weight: 700;
  font-size: 1rem;
  text-align: center;
  text-decoration: none;
  z-index: 50;
  box-shadow: 0 8px 32px rgba(26,189,168,0.4);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease, transform 0.3s ease;
}
/* موبايل فقط */
@media (max-width: 768px) {
  #fcta.visible {
    opacity: 1;
    pointer-events: auto;
  }
}
/* إخفاء على desktop */
@media (min-width: 769px) {
  #fcta { display: none; }
}
</style>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    var btn = document.getElementById('fcta');
    var contact = document.getElementById('contact');
    var footer = document.querySelector('footer'); // إضافة مراقبة الفوتر أيضاً
    if (!btn) return;

    // Haptic feedback on click (Android)
    btn.addEventListener('click', function(){
      if (navigator.vibrate) navigator.vibrate(10);
    });

    // استخدام IntersectionObserver لإخفاء الزر عند الوصول للأسفل
    var observer = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if (e.isIntersecting) {
          btn.classList.remove('visible');
        } else if (window.scrollY > 200) {
          btn.classList.add('visible'); // إعادة الإظهار إذا ارتفعنا للأعلى
        }
      });
    }, { threshold: 0.1 });

    if (contact) observer.observe(contact);
    if (footer) observer.observe(footer);

    // إظهار الزر عند النزول
    window.addEventListener('scroll', function(){
      // التحقق السريع قبل الإضافة (إذا لم نكن عند الفوتر/التواصل)
      var isBottomVisible = false;
      if(contact && contact.getBoundingClientRect().top < window.innerHeight) isBottomVisible = true;
      if(footer && footer.getBoundingClientRect().top < window.innerHeight) isBottomVisible = true;

      if (window.scrollY > 200 && !isBottomVisible) {
        btn.classList.add('visible');
      } else {
        btn.classList.remove('visible');
      }
    }, { passive: true });
  });
</script>
