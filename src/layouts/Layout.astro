---
import { ViewTransitions } from 'astro:transitions';
import Effects from '../components/Effects.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.jsx';

interface Props { title: string; }
const { title } = Astro.props;
---
<!doctype html>
<html lang="ar" dir="rtl" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <ViewTransitions />
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap');
      :root { --c-teal: #1ABDA8; --c-blue: #0F6E7E; --c-dark: #070F1A; --c-light: #F8FAFB; }
      body { font-family: 'Tajawal', sans-serif; background-color: var(--c-light); color: var(--c-dark); overflow-x: hidden; }
      ::view-transition-old(halo-motif), ::view-transition-new(halo-motif) {
        animation-duration: 0.6s; animation-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
      }
    </style>
  </head>
  <body>
    <Navbar client:load />
    <slot />
    <Footer client:load />
    <Effects />
  </body>
</html>
