---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ar" dir="rtl">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="أورا للتسويق - هندسة الحضور الرقمي الفاخر" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<!-- استدعاء خط تجوال الفخم للغة العربية -->
		<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#FDFDFD] text-[#1A1D20] font-['Tajawal',sans-serif] antialiased overflow-x-hidden selection:bg-[#58A8B4] selection:text-white">
		<slot />
	</body>
</html>
