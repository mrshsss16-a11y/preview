---
import { ViewTransitions } from 'astro:transitions';
import LoadingScreen from '../components/LoadingScreen.astro';
import Effects from '../components/Effects.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.jsx';

interface Props { 
  title: string; 
  description?: string; 
  navTheme?: 'dark' | 'light'; 
}

const { 
  title, 
  description = "وكالة آورا للتسويق الرقمي في مكة المكرمة. نصنع هالتك الفارقة عبر خدمات الـ SEO، تصميم الهوية البصرية، وإدارة الحملات الإعلانية لتحقيق نتائج حقيقية وعائد استثمار مضاعف.", 
  navTheme = 'dark' 
} = Astro.props;
---
<!doctype html>
<html lang="ar" dir="rtl" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://pub-8dda25e2267049d98f8e98a0237e7096.r2.dev/cropped-%D8%B4%D8%B9%D8%A7%D8%B1-%D8%A3%D9%88%D8%B1%D8%A7-02-2-1.webp" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap">
    
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" media="print" onload="this.media='all'">
    
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap">
    </noscript>

    <link rel="preload" as="image" href="https://pub-8dda25e2267049d98f8e98a0237e7096.r2.dev/cropped-%D8%B4%D8%B9%D8%A7%D8%B1-%D8%A3%D9%88%D8%B1%D8%A7-02-2-1.webp">

    <ViewTransitions />
    <script src="../scripts/reveal.ts"></script>
    <style is:global>
      :root { --c-teal: #1ABDA8; --c-blue: #0F6E7E; --c-dark: #070F1A; --c-light: #F8FAFB; }
      /* الخط الافتراضي للنظام يظهر فوراً، وبمجرد تحميل تجوال يتم التبديل بنعومة بفضل swap */
      body { font-family: 'Tajawal', system-ui, -apple-system, sans-serif; background-color: var(--c-light); color: var(--c-dark); overflow-x: hidden; }
      ::view-transition-old(halo-motif), ::view-transition-new(halo-motif) { animation-duration: 0.6s; animation-timing-function: cubic-bezier(0.16, 1, 0.3, 1); }
    </style>
  </head>
  <body>
    <LoadingScreen />
    <Navbar client:load theme={navTheme} />
    <slot />
    <Footer client:load />
    <Effects />
  </body>
</html>
